#!/usr/bin/env python3
"""smoke_kill_drill — live drill that verifies L15 kill-switch separation.

Creates a lease (spins up a RunPod worker), submits an inference request to
verify the worker is alive, triggers the account-wide kill switch, and captures
timing evidence. This is the third tier of the 4-tier pre-spend validation.

Exit criteria (§16 Milestone 1):
  - POST /v1/admin/kill-switch returns KillReport with total_duration_ms < 30000
  - kill_log row created with errors: []
  - Presigned URLs return 403 after kill switch activation

Usage:
    PITWALL_BASE_URL=http://pitwall.tail-net:8080 \\
    PITWALL_ADMIN_API_KEY=... \\
    RUNPOD_API_KEY=... \\
    DATABASE_URL=... \\
    ./tools/smoke_kill_drill --capability embedding.bge-m3

Exit 0 on success, non-zero on failure.
"""

from __future__ import annotations

import argparse
import os
import sys
import time


def _is_live() -> bool:
    try:
        from pitwall.live import is_live as _is_live
    except ImportError:
        return False
    return _is_live()


def _main() -> None:
    parser = argparse.ArgumentParser(
        description="Live kill-drill test for Pitwall L15 kill-switch.",
    )
    parser.add_argument(
        "--capability",
        default="embedding.bge-m3",
        help="Capability name to test (default: embedding.bge-m3)",
    )
    parser.add_argument(
        "--pitwall-url",
        default=os.environ.get("PITWALL_BASE_URL", "http://pitwall.tail-net:8080"),
        dest="pitwall_url",
        help="Pitwall base URL (default: from PITWALL_BASE_URL env var)",
    )
    parser.add_argument(
        "--admin-api-key",
        default=os.environ.get("PITWALL_ADMIN_API_KEY", ""),
        dest="admin_api_key",
        help="PITWALL_ADMIN_API_KEY (default: from env)",
    )
    parser.add_argument(
        "--runpod-api-key",
        default=os.environ.get("RUNPOD_API_KEY", ""),
        dest="runpod_api_key",
        help="RUNPOD_API_KEY (default: from env)",
    )
    parser.add_argument(
        "--lease-timeout",
        type=int,
        default=120,
        dest="lease_timeout",
        help="Seconds to wait for lease to become active (default: 120)",
    )
    parser.add_argument(
        "--kill-reason",
        default="smoke_kill_drill live test",
        dest="kill_reason",
        help="Reason for kill switch activation (default: smoke_kill_drill live test)",
    )
    args = parser.parse_args()

    if not _is_live():
        print(
            "[smoke_kill_drill] SKIP: live drill requires RUNPOD_LIVE=1 and PITWALL_BASE_URL",
            file=sys.stderr,
        )
        sys.exit(1)

    if not args.admin_api_key:
        print(
            "[smoke_kill_drill] FAIL: PITWALL_ADMIN_API_KEY environment variable is required",
            file=sys.stderr,
        )
        sys.exit(1)

    if not args.runpod_api_key:
        print(
            "[smoke_kill_drill] FAIL: RUNPOD_API_KEY environment variable is required",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        import httpx
    except ImportError:
        print(
            "[smoke_kill_drill] FAIL: httpx package not installed. Install with: pip install httpx",
            file=sys.stderr,
        )
        sys.exit(1)

    base_url = args.pitwall_url.rstrip("/")
    headers = {
        "Authorization": f"Bearer {args.runpod_api_key}",
        "Content-Type": "application/json",
    }
    admin_headers = {
        "Authorization": f"Bearer {args.admin_api_key}",
        "Content-Type": "application/json",
    }

    print(f"[smoke_kill_drill] Base URL: {base_url}")
    print(f"[smoke_kill_drill] Capability: {args.capability}")

    # Step 1: Create a lease
    print("[smoke_kill_drill] Step 1: Creating lease...")
    try:
        with httpx.Client(base_url=base_url, timeout=60.0) as client:
            lease_response = client.post(
                "/v1/leases",
                json={
                    "capability_id": args.capability,
                    "dry_run": False,
                },
                headers=headers,
            )
    except Exception as exc:
        print(f"[smoke_kill_drill] FAIL: Lease creation request failed: {exc}", file=sys.stderr)
        sys.exit(1)

    if lease_response.status_code >= 400:
        print(f"[smoke_kill_drill] FAIL: Lease creation failed: {lease_response.status_code} {lease_response.text}", file=sys.stderr)
        sys.exit(1)

    lease_data = lease_response.json()
    lease_id = lease_data.get("id")
    lease_state = lease_data.get("state")
    print(f"[smoke_kill_drill] Lease created: id={lease_id} state={lease_state}")

    if not lease_id:
        print("[smoke_kill_drill] FAIL: No lease_id in response", file=sys.stderr)
        sys.exit(1)

    # Step 2: Wait for lease to become active
    print(f"[smoke_kill_drill] Step 2: Waiting for lease {lease_id} to become active (timeout={args.lease_timeout}s)...")
    lease_poll_start = time.perf_counter()
    active = False
    while time.perf_counter() - lease_poll_start < args.lease_timeout:
        try:
            with httpx.Client(base_url=base_url, timeout=30.0) as client:
                get_response = client.get(
                    f"/v1/leases/{lease_id}",
                    headers=headers,
                )
            if get_response.status_code == 200:
                state = get_response.json().get("state")
                print(f"[smoke_kill_drill]   lease state={state}")
                if state == "active":
                    active = True
                    break
        except Exception as exc:
            print(f"[smoke_kill_drill] WARN: Lease poll failed: {exc}", file=sys.stderr)
        time.sleep(5)

    if not active:
        print(f"[smoke_kill_drill] FAIL: Lease did not become active within {args.lease_timeout}s", file=sys.stderr)
        sys.exit(1)

    print("[smoke_kill_drill] Lease is active")

    # Step 3: Submit inference request to verify worker is alive
    print("[smoke_kill_drill] Step 3: Submitting inference request to verify worker...")
    try:
        with httpx.Client(base_url=base_url, timeout=60.0) as client:
            inf_response = client.post(
                "/v1/inference",
                json={
                    "capability_id": args.capability,
                    "texts": ["hello world"],
                },
                headers=headers,
            )
    except Exception as exc:
        print(f"[smoke_kill_drill] FAIL: Inference request failed: {exc}", file=sys.stderr)
        sys.exit(1)

    if inf_response.status_code >= 400:
        print(f"[smoke_kill_drill] FAIL: Inference failed: {inf_response.status_code} {inf_response.text}", file=sys.stderr)
        sys.exit(1)

    workload_id = inf_response.headers.get("X-Pitwall-Workload-ID", "unknown")
    print(f"[smoke_kill_drill] Inference successful: workload_id={workload_id}")

    # Step 4: Trigger kill switch
    print(f"[smoke_kill_drill] Step 4: Triggering kill switch (reason={args.kill_reason})...")
    kill_start = time.perf_counter()
    try:
        with httpx.Client(base_url=base_url, timeout=60.0) as client:
            kill_response = client.post(
                "/v1/admin/kill-switch",
                json={
                    "reason": args.kill_reason,
                    "terminate_compute": True,
                },
                headers=admin_headers,
            )
    except Exception as exc:
        print(f"[smoke_kill_drill] FAIL: Kill switch request failed: {exc}", file=sys.stderr)
        sys.exit(1)

    kill_duration = time.time() - kill_start

    if kill_response.status_code >= 400:
        print(f"[smoke_kill_drill] FAIL: Kill switch failed: {kill_response.status_code} {kill_response.text}", file=sys.stderr)
        sys.exit(1)

    kill_data = kill_response.json()
    total_duration_ms = kill_data.get("total_duration_ms", -1)
    errors = kill_data.get("errors", [])
    pods_terminated = kill_data.get("pods_terminated", -1)
    devices_removed = kill_data.get("devices_removed", -1)
    tailscale_acl_updated = kill_data.get("tailscale_acl_updated", False)

    print("[smoke_kill_drill] Kill switch response:")
    print(f"  total_duration_ms: {total_duration_ms}")
    print(f"  pods_terminated: {pods_terminated}")
    print(f"  devices_removed: {devices_removed}")
    print(f"  tailscale_acl_updated: {tailscale_acl_updated}")
    print(f"  errors: {errors}")
    print(f"  wall_clock_duration: {kill_duration:.2f}s")

    # Step 5: Verify exit criteria
    print("[smoke_kill_drill] Step 5: Verifying exit criteria...")

    all_passed = True

    if total_duration_ms >= 30000:
        print(f"[smoke_kill_drill] FAIL: total_duration_ms {total_duration_ms} >= 30000 (must be < 30s)", file=sys.stderr)
        all_passed = False
    else:
        print(f"[smoke_kill_drill] PASS: total_duration_ms {total_duration_ms} < 30000")

    if errors:
        print(f"[smoke_kill_drill] FAIL: kill_log errors must be [], got {errors}", file=sys.stderr)
        all_passed = False
    else:
        print("[smoke_kill_drill] PASS: kill_log errors: []")

    # Summary
    print("\n[smoke_kill_drill] === Kill Drill Summary ===")
    print(f"  Lease ID: {lease_id}")
    print(f"  Workload ID: {workload_id}")
    print(f"  Kill duration: {kill_duration:.2f}s (wall clock)")
    print(f"  Kill duration: {total_duration_ms}ms (reported)")
    print(f"  Pods terminated: {pods_terminated}")
    print(f"  Exit criteria: {'ALL PASSED' if all_passed else 'FAILED'}")

    if all_passed:
        print("[smoke_kill_drill] Kill drill passed")
        sys.exit(0)
    else:
        print("[smoke_kill_drill] FAIL: Kill drill failed", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    _main()
