# -------- Required --------
RUNPOD_API_KEY=                              # Pitwall control-plane access to RunPod
DATABASE_URL=                                # postgresql://...?schema=pitwall
REDIS_URL=                                   # redis://...:6379/4

# -------- Optional config file --------
# Precedence: CLI/direct settings and env vars > PITWALL_CONFIG_FILE or ./pitwall.toml > defaults.
# TOML keys may use lower-snake-case settings names (runpod_api_key) or env-style names (RUNPOD_API_KEY).
PITWALL_CONFIG_FILE=                         # optional path to pitwall.toml; defaults to ./pitwall.toml when present

# -------- Optional (install `pitwall[tracing]`) --------
LANGFUSE_HOST=                               # for trace emission
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# -------- Optional --------
RUNPOD_LIVE=                                 # leave empty (hermetic, default) or 0 to skip @pytest.mark.live tests; set to 1 to run live tests against real RunPod endpoints (DANGEROUS - costs money)
PITWALL_RUN_LIVE=                            # alias for RUNPOD_LIVE (same behavior as RUNPOD_LIVE)
PITWALL_BASE_URL=                            # base URL of the running Pitwall server; required when RUNPOD_LIVE=1 and used when PITWALL_EMBEDDING_VIA_PITWALL=true

PITWALL_ADMIN_SECRET=                        # enables /v1/admin/*; unset means admin routes return 401
PITWALL_API_TOKEN=                           # required with PITWALL_ADMIN_SECRET for non-loopback API binding
PITWALL_API_SCOPED_TOKENS=                   # optional JSON: {"opaque-token":["read","spend"]}; see SECURITY.md
PITWALL_INBOUND_RATE_LIMIT=120/60s           # default inbound API token bucket; set off only for loopback development
PITWALL_API_MAX_BODY_BYTES=8388608            # hard limit for all REST request bodies, including chunked bodies
PITWALL_API_MAX_CONCURRENCY=100               # Uvicorn in-flight connection/task bound
PITWALL_WEBHOOK_SECRET=                      # required for non-loopback webhook binding
PITWALL_WEBHOOK_PREVIOUS_SECRETS=[]          # JSON array accepted during zero-downtime inbound HMAC rotation
PITWALL_WEBHOOK_MAX_BODY_BYTES=1048576       # hard limit enforced while streaming request bytes
PITWALL_WEBHOOK_RATE_LIMIT=120/60s           # per-client receiver token bucket
PITWALL_WEBHOOK_MAX_CONCURRENCY=50           # Uvicorn in-flight connection/task bound
PITWALL_WEBHOOK_ENCRYPTION_KEYS=             # JSON of version -> URL-safe base64 32-byte AES key
PITWALL_WEBHOOK_ENCRYPTION_CURRENT_KEY=v1    # version used for new outbound webhook secrets
PITWALL_UNSAFE_ALLOW_INSECURE_BIND=          # development-only override; never use in release deployments
R2_ENDPOINT=                                 # for pod log forwarding (worker images)
R2_ACCESS_KEY=                               # legacy parent key id; never forwarded to pods
R2_SECRET_KEY=                               # legacy parent secret; never forwarded to pods
R2_PARENT_ACCESS_KEY_ID=                     # parent key id for Cloudflare temp-access-credentials
R2_BUCKET_STAGING=pitwall-staging
R2_TEMP_CREDENTIALS_ENABLED=auto             # auto | true | false
R2_TEMP_CREDENTIALS_REQUIRED=false           # fail launch if temp vending config is incomplete
R2_TEMP_CREDENTIAL_TTL_S=21600               # 6h default, Cloudflare max 604800
R2_TEMP_CREDENTIAL_PERMISSION=object-read-write
R2_TEMP_CREDENTIAL_PREFIXES=debug-logs/      # comma-separated prefixes scoped into the bucket
R2_TEMP_CREDENTIAL_OBJECTS=                  # optional comma-separated exact object keys
CLOUDFLARE_ACCOUNT_ID=                       # account containing the R2 bucket
CLOUDFLARE_API_TOKEN=                        # token allowed to vend R2 temporary credentials

PITWALL_MONTHLY_BUDGET_USD=50.0              # budget gate hard cap
PITWALL_PER_REQUEST_MAX_USD=10.0             # per-request cap
PITWALL_BUDGET_LOCK_KEY=5494545452575544     # 8-byte big-endian of b"PITWBUDG"
PITWALL_BUDGET_BREACH_KILL_MODE=disabled            # disabled|shadow|armed: auto-fire kill switch on budget exhaustion (default disabled)
PITWALL_BUDGET_BREACH_KILL_HEADROOM_FLOOR_USD=0.0   # headroom (USD) at/below which an armed breach escalates to kill (0 = fully exhausted)

# Resend email notifications for budget alerts
RESEND_API_KEY=                              # Resend API key for sending budget alert emails
PITWALL_ALERT_FROM=                         # Sender email address (e.g., alerts@example.com)
PITWALL_ALERT_TO=                           # Recipient email address for budget alerts

PITWALL_DEFAULT_LEASE_TTL_S=7200             # 2h default for pod leases
PITWALL_LEASE_ADVANCE_WARNING_MIN=15,5       # T-15 and T-5 pub/sub events
PITWALL_VOLUME_ATTACH_TIMEOUT_S=300          # L7
PITWALL_IMAGE_PULL_TIMEOUT_S=600             # default must be >= pod startup timeout
PITWALL_RUNPOD_CAPACITY_ERROR_SUBSTRINGS=    # optional comma/newline list overriding L6 capacity-error substrings

PITWALL_MCP_TRANSPORT=stdio                    # public alpha supports local stdio only
PITWALL_BIND_IP=127.0.0.1                     # canonical Compose host binding
PITWALL_TAILSCALE_IP=                         # optional Tailscale integration metadata
PITWALL_WEBHOOK_PUBLIC_URL=                  # tailnet URL Pitwall registers with RunPod
PITWALL_WEBHOOK_RECEIVER_PORT=8082
PITWALL_COST_EXPORTER_PORT=9109
PITWALL_COST_EXPORTER_MAX_CONCURRENCY=20
TAILSCALE_OAUTH_CLIENT_ID=                   # kill-switch device cleanup
TAILSCALE_OAUTH_CLIENT_SECRET=               # kill-switch device cleanup
TAILSCALE_TAILNET=                           # kill-switch target tailnet

PITWALL_AUDIT_GPU_IDS=NVIDIA H100 80GB HBM3,NVIDIA L4,NVIDIA A100 80GB  # canonical GPU names for audit
PITWALL_AUDIT_CLOUD_TYPE=SECURE               # cloud_type used by audit CLI
PITWALL_AUDIT_EXEC_TIMEOUT_S=3600             # execution timeout for audit check 5
PITWALL_AUDIT_EXEC_TIMEOUT_MAX_S=7200         # max execution timeout for audit check 5
PITWALL_AUDIT_QUEUE_TIME_S=300                # expected queue time for audit check 6
PITWALL_AUDIT_STARTUP_TIMEOUT_S=600           # pod startup timeout for audit check 11

# RunPod-specific (per-capability, can also live in capability config)
RUNPOD_NETWORK_VOLUME_ID=
RUNPOD_DATA_CENTER_ID=
RUNPOD_REGISTRY_AUTH_ID=
RUNPOD_REGISTRY_AUTH_ID_GHCR=
RUNPOD_REGISTRY_AUTH_ID_GITLAB=
RUNPOD_REGISTRY_AUTH_ID_DOCKER_HUB=
RUNPOD_REST_API_URL=                          # defaults to https://rest.runpod.io/v1
PITWALL_CLOUD_WORKER_IMAGE=                   # operator-supplied reviewed image; Pitwall publishes no GPU worker
HUGGINGFACE_TOKEN=                           # HF access token for model downloads in prewarm pods

# Embedding routing via Pitwall broker
PITWALL_EMBEDDING_VIA_PITWALL=                # true | false — route embeddings through Pitwall instead of direct RunPod
# Uses PITWALL_BASE_URL as the Pitwall server base URL.

# Service ports & hosts
PITWALL_API_HOST=127.0.0.1                    # REST API bind host for bare python -m entrypoint
PITWALL_API_PORT=8080                          # REST API listen port
PITWALL_WEBHOOK_HOST=127.0.0.1                # webhook receiver bind host for bare python -m entrypoint
PITWALL_COST_EXPORTER_HOST=127.0.0.1          # cost exporter bind host for bare python -m entrypoint

# Ops: backup/restore drill & archival
PITWALL_DATABASE_URL=                          # source DB URL for the backup drill (pg_dump source)
PITWALL_DRILL_ARTIFACTS_DIR=                   # local dir for DR drill evidence artifacts
PITWALL_RETENTION_MODE=off                    # off | archive | archive-purge (canonical Compose defaults to archive-purge)
PITWALL_RETENTION_DAYS=90
PITWALL_RETENTION_BATCH_SIZE=1000             # 1..10000 records per scheduled run
PITWALL_ARCHIVE_DIR=                           # encrypted archive directory; mode 0700 required
PITWALL_ARCHIVE_ENCRYPTION_KEY=               # URL-safe base64 encoding of exactly 32 random bytes
PITWALL_ARCHIVE_ENCRYPTION_KEY_VERSION=v1     # retain old keys while their archives exist

# Network-volume S3 file access — credentials for RunPod's S3-compatible
# endpoint; RUNPOD_S3_* take precedence, falling back to the standard AWS_* names.
RUNPOD_S3_ACCESS_KEY=                          # RunPod S3 access key for network-volume file ops
RUNPOD_S3_SECRET_KEY=                          # RunPod S3 secret key for network-volume file ops
AWS_ACCESS_KEY_ID=                             # fallback S3 access key (standard AWS env name)
AWS_SECRET_ACCESS_KEY=                         # fallback S3 secret key (standard AWS env name)
